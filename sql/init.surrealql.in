define sequence mindustry_profile_short_id_seq;

define function fn::mindustry_fetch_user($search: string, $check_uuid: bool) {
    let $short_id = mod::try::int($search);
    if $short_id = none {
        let $uuid = mod::try::uuid($search);
        if $uuid != none {
            let $x = select * from only mindustry_profile where record::id(id) = $uuid order by last_joined desc limit 1;
            if $x != none {
                return {
                    name: $x.last_name,
                    user_id: <string> record::id($x.user),
                    profile_id: <string> record::id($x.id),
                    short_id: $x.short_id,
                    uuid: select value <string> record::id(id) from only mindustry_user where profile = $x.id limit 1,
                };
            };

            let $x = select * from only type::record("user", $uuid);
            if $x != none {
                let $y = select * from only mindustry_profile where user = $x order by last_joined desc limit 1;
                return {
                    name: $y.last_name,
                    user_id: <string> record::id($y.user),
                    profile_id: <string> record::id($y.id),
                    short_id: $x.short_id,
                    uuid: select value <string> record::id(id) from only mindustry_user where profile = $y.id limit 1,
                };
            };
        } else if $search.len() = 6 {
            let $x = select * from only mindustry_profile where type::string(record::id(id)).ends_with($search) order by last_joined desc limit 1;
            if $x != none {
                return {
                    name: $x.last_name,
                    user_id: <string> record::id($x.user),
                    profile_id: <string> record::id($x.id),
                    short_id: $x.short_id,
                    uuid: select value <string> record::id(id) from only mindustry_user where profile = $x.id limit 1,
                };
            };
        };
    } else {
        let $x = select * from only mindustry_profile where short_id != none && type::string(short_id) == $short_id;
        if $x != none {
            return {
                name: $x.last_name,
                user_id: <string> record::id($x.user),
                profile_id: <string> record::id($x.id),
                short_id: $x.short_id,
                uuid: select value <string> record::id(id) from only mindustry_user where profile = $x.id limit 1,
            };
        };
    };

    if !$check_uuid { return none; };

    let $x = select value id from only type::record("mindustry_user", $search);
    if $x != none {
        return {
            name: $x.profile.last_name,
            user_id: <string> record::id($x.profile.user),
            profile_id: <string> record::id($x.profile),
            short_id: $x.profile.short_id,
            uuid: <string> record::id($x),
        };
    };

    return none;
};

define function fn::mindustry_last_name($user: record<user>) {
    let $x = select *
        from only mindustry_profile
        where
            user = $user
        order by last_joined
        desc limit 1;
    let $id_string = if $x.shortId != none { type::string($x.shortId) }
                     else {
                         let $s = type::string(record::id($x.id));
                         $s.slice($s.len() - 6);
                     };
    return $x.last_name + " [#dadada][[" + $id_string + "]";
};

# 0 - all ok
# 1 - verification required
# 2 - ban instantly
define function fn::sus_update_obtain(
    $scopes: {
        ip: string,          ip_promised: option<bool>,
        isp: option<string>, ips_promised: option<bool>,
    },
    $extra_sus: float) -> int
{
    let $record = type::record("sus_ip", $scopes.ip);
    let $now = time::now();

    let $sus_ip = if $record.exists() || $scopes.ip_promised = true {
        let $x = select * from only $record;
        let $passed = <float> ($now - $x.last_update).millis() / 1000;
        let $sus = math::max([0, $x.sus - $passed]);
        let $sus = math::clamp(0, $sus + $extra_sus, 3000);
        update only $record content { sus: $sus, last_update: $now };
        $sus
    } else {
        create only $record content {
            last_update: $now,
            sus: math::clamp(0, $extra_sus, 3000),
        } return value sus
    };

    let $sus_isp = if $scopes.isp != none {
        let $record = type::record("sus_isp", $scopes.isp);

        let $sus_ip = if $record.exists() || $scopes.isp_promised = true {
            let $x = select * from only $record;
            let $passed = <float> ($now - $x.last_update).millis() / 1000;
            let $sus = math::max([0, $x.sus - $passed]);
            let $sus = math::clamp(0, $sus + $extra_sus * 0.5, 6000);
            update only $record content { sus: $sus, last_update: $now };
            $sus
        } else {
            create only $record content {
                last_update: $now,
                sus: math::clamp(0, $extra_sus, 6000),
            } return value sus
        };
    } else { 0 };

    return if $sus_ip >= 2000 { 2 }
           else if $sus_ip >= 1000 || $sus_isp >= 1000 { 1 }
           else { 0 };
};

define function fn::rng_uuid_v7_nonum() -> uuid {
    for $_ in 0..99999999 {
        let $uuid = rand::uuid::v7();
        if !$uuid.to_string().slice(-6).is_numeric() {
            return $uuid;
        };
    };
    return fn::rng_uuid_v7_nonum();
};

define function fn::mindustry_update_profile($profile: record<mindustry_profile>) -> {
    new_short_id: option<int>,
} {
    let $new_short_id: option<int> = if $profile.short_id = none && ($profile.user.mindustry_permission_level > 0 ||
        $profile.play_time > 1h) {
        update only $profile set short_id = sequence::nextval("mindustry_profile_short_id_seq") return value short_id;
    } else { none };

    # TODO: Ranks.

    return { new_short_id: $new_short_id };
};

define function fn::mindustry_login($uuid: string, $usid: string, $ip: string, $isp: option<string>,
    $server: string, $key: option<bytes>, $new_name: string, $server_id: string,
) {

    let $tmp = select disabled from only type::record("mindustry_abandoned_user", $uuid);
    if $tmp != none {
        return $tmp;
    };

    let $now = time::now();

    # TODO: Graylist.

    # Not cheap IP checks.

    let $tmp = select * from only mindustry_votekick where server_name = $server && !pardoned && expires > $now && array::any(user->(logged where $now - last_used < 4w)->mindustry_ip, |$x| $x.id() = $ip) order by expires asc limit 1;
    if $tmp != none {
        let $initiator = fn::mindustry_last_name($tmp.initiator);
        let $votes = $tmp.votes.map(|$x| fn::mindustry_last_name($x));
        return {
            disabled: 11,
            id: <string> record::id($tmp.id),
            user: <string> record::id($tmp.user),
            initiator: $initiator,
            votes: $votes,
            reason: $tmp.reason,
            expires: if $tmp.expires = none { none } else { $tmp.expires.millis() },
        };
    };
    let $tmp = select * from only mindustry_kick where server_name = $server && !pardoned && (expires = none || expires > $now) && array::any(user->(logged where $now - last_used < 4w)->mindustry_ip, |$x| $x.id() = $ip) order by expires asc limit 1;
    if $tmp != none {
        let $admin = if $tmp.admin = none { "<Console>" } else { fn::mindustry_last_name($tmp.admin) };
        return {
            disabled: 9,
            id: <string> record::id($tmp.id),
            user: <string> record::id($tmp.user),
            admin: $admin,
            reason: $tmp.reason,
            expires: if $tmp.expires = none { none } else { $tmp.expires.millis() },
        };
    };
    let $tmp = select * from only mindustry_ban where !pardoned && (expires = none || expires > $now) && array::any(user->(logged where $now - last_used < 4w)->mindustry_ip, |$x| $x.id() = $ip) order by expires asc limit 1;
    if $tmp != none {
        let $admin = if $tmp.admin = none { "<Console>" } else { fn::mindustry_last_name($tmp.admin) };
        return {
            disabled: 8,
            id: <string> record::id($tmp.id),
            user: <string> record::id($tmp.user),
            admin: $admin,
            reason: $tmp.reason,
            server: $tmp.server_name,
            expires: if $tmp.expires = none { none } else { $tmp.expires.millis() },
        };
    };

    # Not cheap USID checks.

    let $tmp = select * from only mindustry_votekick
               where !pardoned &&
                     server_name = $server &&
                     expires > $now &&
                     array::any(
                         user->(logged where $now - last_used < 4w)->mindustry_usid,
                         |$x| $x.server_ip = $server_ip && $x.usid = $usid
                     )
               order by expires asc limit 1;
    if $tmp != none {
        let $initiator = fn::mindustry_last_name($tmp.initiator);
        let $votes = $tmp.votes.map(|$x| fn::mindustry_last_name($x));
        return {
            disabled: 11,
            id: <string> record::id($tmp.id),
            user: <string> record::id($tmp.user),
            initiator: $initiator,
            votes: $votes,
            reason: $tmp.reason,
            expires: if $tmp.expires = none { none } else { $tmp.expires.millis() },
        };
    };
    let $tmp = select * from only mindustry_kick
               where !pardoned &&
                     server_name = $server &&
                     (expires = none || expires > $now) &&
                     array::any(
                         user->(logged where $now - last_used < 4w)->mindustry_usid,
                         |$x| $x.server_ip = $server_ip && $x.usid = $usid
                     )
               order by expires asc limit 1;
    if $tmp != none {
        let $admin = if $tmp.admin = none { "<Console>" } else { fn::mindustry_last_name($tmp.admin) };
        return {
            disabled: 9,
            id: <string> record::id($tmp.id),
            user: <string> record::id($tmp.user),
            admin: $admin,
            reason: $tmp.reason,
            expires: if $tmp.expires = none { none } else { $tmp.expires.millis() },
        };
    };
    let $tmp = select * from only mindustry_ban
               where !pardoned &&
                     (expires = none || expires > $now) &&
                     array::any(
                         user->(logged where $now - last_used < 4w)->mindustry_usid,
                         |$x| $x.server_ip = $server_ip && $x.usid = $usid
                     )
               order by expires asc limit 1;
    if $tmp != none {
        let $admin = if $tmp.admin = none { "<Console>" } else { fn::mindustry_last_name($tmp.admin) };
        return {
            disabled: 8,
            id: <string> record::id($tmp.id),
            user: <string> record::id($tmp.user),
            admin: $admin,
            reason: $tmp.reason,
            server: $tmp.server_name,
            expires: if $tmp.expires = none { none } else { $tmp.expires.millis() },
        };
    };

    # And thus, we log in.

    let $process = |$muser: record<mindustry_user>, $x: record<mindustry_profile>, $is_new: bool| {
        let $user = $x.user;

        select key from mindustry_profile where user = $x.user and key != none;

        if $x.disabled != 0 {
            return $x.{disabled};
        };

        # Cheap ID checks.

        let $tmp = select * from only mindustry_votekick where user = $x.user and expires > $now and server_name = $server and !pardoned order by expires asc limit 1;
        if $tmp != none {
            let $initiator = fn::mindustry_last_name($tmp.initiator);
            let $votes = $tmp.votes.map(|$x| fn::mindustry_last_name($x));
            return {
                disabled: 11,
                id: <string> record::id($tmp.id),
                user: <string> record::id($tmp.user),
                initiator: $initiator,
                votes: $votes,
                reason: $tmp.reason,
                expires: if $tmp.expires = none { none } else { $tmp.expires.millis() },
            };
        };
        let $tmp = select * from only mindustry_kick where user = $x.user and (expires = none || expires > $now) and server_name = $server and !pardoned order by expires asc limit 1;
        if $tmp != none {
            let $admin = if $tmp.admin = none { "<Console>" } else { fn::mindustry_last_name($tmp.admin) };
            return {
                disabled: 9,
                id: <string> record::id($tmp.id),
                user: <string> record::id($tmp.user),
                admin: $admin,
                reason: $tmp.reason,
                expires: if $tmp.expires = none { none } else { $tmp.expires.millis() },
            };
        };
        let $tmp = select * from only mindustry_ban where user = $x.user and (expires = none || expires > $now) and !pardoned order by expires asc limit 1;
        if $tmp != none {
            let $admin = if $tmp.admin = none { "<Console>" } else { fn::mindustry_last_name($tmp.admin) };
            return {
                disabled: 8,
                id: <string> record::id($tmp.id),
                user: <string> record::id($tmp.user),
                admin: $admin,
                reason: $tmp.reason,
                server: $tmp.server_name,
                expires: if $tmp.expires = none { none } else { $tmp.expires.millis() },
            };
        };

        # TODO: Graylist.

        if $x.disabled != 0 {
            return {
                user_id: record::id($x.user),
                id: record::id($x),
                disabled: $x.disabled,
                short_id: $x.short_id,
                set_name: $x.set_name,
            };
        };

        update $x set last_joined = time::now(), last_name = $new_name;

        let $ip_t = upsert only type::record("mindustry_ip", $ip) return value id;
        let $logged_t = select value ->(logged where out = $ip_t)[0] from only $user;
        let $logged_t = if $logged_t = none { relate $user->logged->$ip_t } else { $logged_t };
        update only $logged_t set last_used = time::now();

        let $usid_t = upsert only mindustry_usid content { usid: $usid, server_ip: $server_ip } return value id;
        let $logged_t = select value ->(logged where out = $usid_t)[0] from only $user;
        let $logged_t = if $logged_t = none { relate $user->logged->$usid_t content { confirmed: false } } else { $logged_t };
        update only $logged_t set last_used = time::now();

        return {
            user_id: record::id($x.user),
            id: record::id($x),
            # rank: if $x.rank = none { null } else { record::id($x.rank) },
            disabled: 0,
            short_id: $x.short_id,
            key_set: $x.key != none,
            permission_level: $x.user.mindustry_permission_level,
            set_name: $x.set_name,
            confirmed: if $x.key = none { $usid.confirmed } else { true },
        };
    };

    let $process_with_key = |$user: record<mindustry_user>, $y: record<mindustry_profile>, $is_new: bool| {
        if $y.key != none && $y.key != $key {
            return { disabled: 3, orig: $y.key };
        };

        return $process($user, $y, $is_new);
    };

    if $key != none {
        let $table = select value id from only mindustry_profile where key = $key;
        if $table != none {
            if fn::sus_update_obtain({ ip: $ip, isp: $isp }, 50) == 2 {
                return { disabled: 12 };
            };
            let $user = select * from only type::record("mindustry_user", $uuid);
            let $user = if $user = none {
                create only mindustry_user content { id: $uuid, profile: $table } return value id;
            } else { $user };
            return $process($user.id, $table, false);
        };
    };

    let $table = select * from only type::record("mindustry_user", $uuid);
    if $table = none {
        if fn::sus_update_obtain({ ip: $ip, isp: $isp }, 600) == 2 {
            return { disabled: 12 };
        };

        let $user = create only user content { id: fn::rng_uuid_v7_nonum() } return value id;
        let $profile = create only mindustry_profile content { id: fn::rng_uuid_v7_nonum(), user: $user, key: none } return value id;
        let $table = create only mindustry_user content { id: $uuid, profile: $profile };

        return $process_with_key($table.id, $profile, true);
    } else {
        if fn::sus_update_obtain({ ip: $ip, isp: $isp }, 50) == 2 {
            return { disabled: 12 };
        };

        return $process_with_key($table.id, $table.profile, false);
    };
};

